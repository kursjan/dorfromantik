{
  "name": "myapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@10.9.4",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "putout . --fix && eslint . --fix",
    "format": "prettier --write .",
    "preview": "vite preview",
    "verify": "npm run typecheck && npm run lint && turbo run test:unit:raw test:ui:raw",
    "test": "npm run typecheck && turbo run test:raw",
    "test:raw": "vitest run",
    "test:unit": "npm run typecheck && turbo run test:unit:raw",
    "test:unit:raw": "vitest run --project=unit",
    "test:ui": "npm run typecheck && turbo run test:ui:raw",
    "test:ui:raw": "vitest run --project=storybook",
    "test:ci": "npm run typecheck && turbo run test:ci:raw",
    "test:ci:raw": "dotenv -e .env.ci -- vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ci": "CI=true PORT=5179 TEST_ENV=ci playwright test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky",
    "check:pre-commit": "lint-staged",
    "check:pre-push": "npm run typecheck && turbo run test:unit:raw test:ui:raw"
  },
  "dependencies": {
    "firebase": "^12.10.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.2.10",
    "@storybook/addon-docs": "^10.2.10",
    "@storybook/addon-onboarding": "^10.2.10",
    "@storybook/addon-vitest": "^10.2.10",
    "@storybook/react-vite": "^10.2.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "eslint-plugin-storybook": "^10.2.10",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "putout": "^42.0.11",
    "storybook": "^10.2.10",
    "turbo": "^2.8.21",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
